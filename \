#include "types.h"

t_zone_type	get_type(size_t size)
{
	t_zone_type	z;

	z = LARGE;
	if (size <= TINY_BLOCK) z = TINY;
	else if (size <= SMALL_BLOCK) z = SMALL;

	return (z);
}

static void	*call_mmap(size_t size)
{
	void	*ptr;

	ptr = mmap(NULL, size, PROT_READ | PROT_WRITE,
			MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);

	if (ptr == MAP_FAILED) return (NULL);

	return (ptr);
}

t_zone	*create_zone(size_t size, t_zone_type type)
{
	size_t		zoneSize;
	t_zone		*zone;

	if (type == TINY) zoneSize = TINY_ZONE;
	if (type == SMALL) zoneSize = SMALL_ZONE;
	else zoneSize = BLOCK_SIZE + size;

	zone = call_mmap(zoneSize + ZONE_SIZE);

	if (zone)
	{
		zone->type = type;
		zone->total = zoneSize;
		zone->next = NULL;
		zone->blocks = NULL;
	}

	return (zone);
}

t_zone	*find_or_create_zone(size_t size)
{
	t_zone_type	type;

	type = get_type(size);
	if (type == LARGE) create_zone(size, type);

	return (NULL);
}
